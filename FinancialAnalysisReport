--Create products profitability view
CREATE OR REPLACE VIEW vw_product_profitability AS
SELECT
    year,
    quarter,
    product_line,
    revenue,
    cost,
    revenue - cost AS profit,

    ROUND(
        CASE 
            WHEN revenue <> 0 
            THEN (revenue - cost) / revenue
            ELSE 0
        END
    ,4) AS profit_margin

FROM product_sales;

--view result
SELECT * 
FROM vw_product_profitability
ORDER BY year, quarter, product_line;

--Create Product YOY view 
CREATE OR REPLACE VIEW vw_product_yoy AS
SELECT
    a.product_line,
    a.year,
    a.quarter,
    a.revenue AS current_revenue,
    b.revenue AS previous_year_revenue,

    a.revenue - b.revenue AS revenue_variance,

    ROUND(
        CASE 
            WHEN b.revenue <> 0 
            THEN (a.revenue - b.revenue) / b.revenue
            ELSE 0
        END
    ,4) AS yoy_growth_percent

FROM vw_product_profitability a
LEFT JOIN vw_product_profitability b
    ON a.product_line = b.product_line
    AND a.quarter = b.quarter
    AND a.year = b.year + 1;

