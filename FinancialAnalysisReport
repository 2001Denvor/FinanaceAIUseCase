--Create view panal summary
CREATE OR REPLACE VIEW vw_pnl_summary AS
SELECT
    g.year,
    g.quarter,
    SUM(CASE WHEN m.pnl_line = 'Revenue' THEN g.amount ELSE 0 END) AS revenue,
    SUM(CASE WHEN m.pnl_line = 'Opex' THEN g.amount ELSE 0 END) AS opex,
    SUM(CASE WHEN m.pnl_line = 'Depreciation' THEN g.amount ELSE 0 END) AS depreciation,
    SUM(CASE WHEN m.pnl_line = 'Tax' THEN g.amount ELSE 0 END) AS tax
FROM gl_transactions g
LEFT JOIN gl_mapping m
ON g.gl_code = m.gl_code
GROUP BY g.year, g.quarter;

--Create P&L summary view
CREATE OR REPLACE VIEW vw_pnl_waterfall AS
SELECT year, quarter, '1. Revenue' AS metric, revenue AS value, 1 as sort_id
FROM vw_pnl_summary
UNION ALL
SELECT year, quarter, '2. Opex', -ABS(opex), 2
FROM vw_pnl_summary
UNION ALL
SELECT year, quarter, '3. Depreciation', -ABS(depreciation), 3
FROM vw_pnl_summary
UNION ALL
SELECT year, quarter, '4. Tax', -ABS(tax), 4
FROM vw_pnl_summary
UNION ALL
SELECT year, quarter, '5. Profit After Tax', 
       revenue + opex + depreciation + tax, 5
FROM vw_pnl_summary;


--Create final corporate P&L view
CREATE OR REPLACE VIEW vw_pnl_final AS
SELECT
    year,
    quarter,
    CONCAT(quarter, ' ', year) AS period,

    revenue,
    opex,
    depreciation,
    tax,

    ABS(opex + depreciation + tax) AS total_expense,

    revenue + opex AS EBITDA,
    revenue + opex + depreciation AS operating_profit,
    revenue + opex + depreciation + tax AS profit_after_tax,

    CASE 
        WHEN revenue <> 0 
        THEN (revenue + opex) / revenue
        ELSE NULL
    END AS EBITDA_margin

FROM vw_pnl_summary;

--Create YOY variance view
-- Modified version for easier charting
CREATE OR REPLACE VIEW vw_yoy_variance AS
SELECT
    a.year,
    a.quarter,
    ROUND(
        CASE 
            WHEN b.revenue <> 0 
            THEN ((a.revenue - b.revenue) / b.revenue) * 100 -- Multiply by 100 here
            ELSE NULL
        END
    ,2) AS yoy_growth_percentage -- Clearer name
FROM vw_pnl_final a
LEFT JOIN vw_pnl_final b
    ON a.quarter = b.quarter AND a.year = b.year + 1;

--Revenue Trend
SELECT
    year,
    quarter,
    period,
    revenue,
    EBITDA,
    operating_profit,
    profit_after_tax,
    EBITDA_margin
FROM vw_pnl_final
ORDER BY year, quarter;


