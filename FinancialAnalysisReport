-- Create a clean view for unbilled accruals (all derived fields included)
CREATE OR REPLACE VIEW vw_accrual_report AS
SELECT 
    c.supplier_name,
    c.gl_code,
    c.amount AS accrual_amount,
    c.service_month,
    YEAR(c.service_month) AS year,
    CONCAT('Q', QUARTER(c.service_month)) AS quarter,

    -- Total accrual across all unbilled circuits
    SUM(c.amount) OVER () AS total_accrual,

    -- Accrual % of total accrual
    c.amount  / SUM(c.amount) OVER () AS accrual_percent,

    -- Aging calculation
    DATEDIFF(CURRENT_DATE(), c.service_month) AS aging_days,
    CASE 
        WHEN DATEDIFF(CURRENT_DATE(), c.service_month) <= 30 THEN '0-30 Days'
        WHEN DATEDIFF(CURRENT_DATE(), c.service_month) <= 60 THEN '31-60 Days'
        ELSE '60+ Days'
    END AS aging_bucket

FROM circuit_list c
LEFT JOIN gl_transactions_with_suppliers g
    ON LOWER(TRIM(c.supplier_name)) = LOWER(TRIM(g.supplier_name))
    AND c.gl_code = g.gl_code
    AND MONTH(c.service_month) = MONTH(g.transaction_date)
    AND YEAR(c.service_month) = YEAR(g.transaction_date)
WHERE g.supplier_name IS NULL  -- only unbilled invoices
ORDER BY c.gl_code, c.supplier_name, c.service_month;

