--Calculate net balance
CREATE OR REPLACE VIEW vw_net_debtor_balance AS
SELECT
    operator_name,
    invoice_date,
    SUM(CASE WHEN transaction_type = 'Debtor' THEN amount ELSE 0 END) -
    SUM(CASE WHEN transaction_type = 'Creditor' THEN amount ELSE 0 END) 
    AS net_balance
FROM voice_operator_transactions
GROUP BY operator_name, invoice_date;

--Calculate agin days
CREATE OR REPLACE VIEW vw_debtor_aging_days AS
SELECT
    operator_name,
    net_balance,
    invoice_date,
    DATEDIFF(day, invoice_date, CURRENT_DATE) AS aging_days
FROM vw_net_debtor_balance;

--Create agin bucket
CREATE OR REPLACE VIEW vw_net_debtor_aging_bucket AS
SELECT
    operator_name,
    net_balance,
    aging_days,
    
    CASE 
        WHEN aging_days BETWEEN 0 AND 30 THEN '0-30 Days'
        WHEN aging_days BETWEEN 31 AND 60 THEN '31-60 Days'
        WHEN aging_days BETWEEN 61 AND 90 THEN '61-90 Days'
        ELSE '90+ Days'
    END AS aging_bucket

FROM vw_debtor_aging_days;

--Final bucket summary
CREATE OR REPLACE VIEW vw_net_debtor_aging_summary AS
SELECT
    operator_name,
    aging_bucket,
    SUM(net_balance) AS total_net_balance
FROM vw_net_debtor_aging_bucket
GROUP BY operator_name, aging_bucket
ORDER BY operator_name;

