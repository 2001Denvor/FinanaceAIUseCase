--Compare YOD vs last year
CREATE OR REPLACE VIEW vw_ytd_variance AS
SELECT
    a.year,
    a.ytd_revenue AS current_ytd,
    b.ytd_revenue AS previous_ytd,
    (a.ytd_revenue - b.ytd_revenue) AS variance,

    ROUND(
        CASE 
            WHEN b.ytd_revenue <> 0
            THEN (a.ytd_revenue - b.ytd_revenue) / b.ytd_revenue
            ELSE 0
        END
    ,4) AS variance_percent

FROM vw_ytd_summary a
LEFT JOIN vw_ytd_summary b
    ON a.year = b.year + 1;


