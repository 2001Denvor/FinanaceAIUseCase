-- Month-end balances per supplier in original FC
CREATE OR REPLACE VIEW vw_fx_revaluation AS

WITH month_end_balance AS (
    SELECT
        supplier_name,
        gl_code,
        LAST_DAY(transaction_date) AS month_end,
        SUM(amount) AS balance_fc
    FROM gl_transactions_with_suppliers
    GROUP BY supplier_name, gl_code, LAST_DAY(transaction_date)
),

joined_fx AS (
    SELECT
        m.supplier_name,
        m.gl_code,
        m.month_end,
        m.balance_fc,
        f.rate_to_lkr,
        (m.balance_fc * f.rate_to_lkr) AS balance_lkr
    FROM month_end_balance m
    LEFT JOIN fx_rates_manual f
        ON m.month_end = f.month_end
)

SELECT
    supplier_name,
    gl_code,
    month_end,
    balance_fc,
    rate_to_lkr,
    balance_lkr,
    LAG(balance_lkr) OVER (
        PARTITION BY supplier_name, gl_code
        ORDER BY month_end
    ) AS prev_balance_lkr,
    balance_lkr -
    LAG(balance_lkr) OVER (
        PARTITION BY supplier_name, gl_code
        ORDER BY month_end
    ) AS reval_gain_loss
FROM joined_fx;

