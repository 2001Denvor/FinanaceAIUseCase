--Quator on quator variance
CREATE OR REPLACE VIEW vw_qoq_variance AS
WITH ordered_data AS (
    SELECT
        year,
        quarter,
        revenue,
        LAG(revenue) OVER (
            PARTITION BY year 
            ORDER BY 
                CASE quarter
                    WHEN 'Q1' THEN 1
                    WHEN 'Q2' THEN 2
                    WHEN 'Q3' THEN 3
                    WHEN 'Q4' THEN 4
                END
        ) AS previous_quarter_revenue
    FROM vw_pnl_final
)

SELECT
    year,
    quarter,
    revenue AS current_revenue,
    previous_quarter_revenue,
    revenue - previous_quarter_revenue AS variance,

    ROUND(
        CASE 
            WHEN previous_quarter_revenue <> 0
            THEN (revenue - previous_quarter_revenue) 
                 / previous_quarter_revenue
            ELSE 0
        END
    ,4) AS variance_percent

FROM ordered_data;
