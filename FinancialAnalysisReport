--Create    YOD view
CREATE OR REPLACE VIEW vw_ytd_summary AS
SELECT
    year,
    SUM(revenue) AS ytd_revenue,
    SUM(EBITDA) AS ytd_ebitda,
    SUM(operating_profit) AS ytd_operating_profit,
    SUM(profit_after_tax) AS ytd_profit_after_tax
FROM vw_pnl_final
GROUP BY year; 


--Compare YOD vs last year
CREATE OR REPLACE VIEW vw_ytd_variance AS
SELECT
    a.year,
    a.ytd_revenue AS current_ytd,
    b.ytd_revenue AS previous_ytd,
    (a.ytd_revenue - b.ytd_revenue) AS variance,

    ROUND(
        CASE 
            WHEN b.ytd_revenue <> 0
            THEN (a.ytd_revenue - b.ytd_revenue) / b.ytd_revenue
            ELSE 0
        END
    ,4) AS variance_percent

FROM vw_ytd_summary a
LEFT JOIN vw_ytd_summary b
    ON a.year = b.year + 1;


                                --Budget vs Actual variance


 --Create Budget vs actual view                               
CREATE OR REPLACE VIEW vw_budget_vs_actual AS
SELECT
    g.year,
    g.quarter,
    m.pnl_line,

    SUM(g.amount) AS actual_amount,
    SUM(b.budget_amount) AS budget_amount,

    SUM(g.amount) - SUM(b.budget_amount) AS variance,

    ROUND(
        CASE 
            WHEN SUM(b.budget_amount) <> 0
            THEN (SUM(g.amount) - SUM(b.budget_amount)) 
                 / SUM(b.budget_amount)
            ELSE 0
        END
    ,4) AS variance_percent

FROM gl_transactions g
LEFT JOIN budget b
    ON g.gl_code = b.gl_code
    AND g.year = b.year
    AND g.quarter = b.quarter
LEFT JOIN gl_mapping m
    ON g.gl_code = m.gl_code
GROUP BY g.year, g.quarter, m.pnl_line;

