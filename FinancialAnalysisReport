CREATE OR REPLACE VIEW vw_fx_revaluation_dashboard_clean AS
WITH monthly_balance AS (
    -- Step 1: Aggregate all transactions per supplier + gl_code + month
    SELECT
        supplier_name,
        gl_code,
        LAST_DAY(transaction_date) AS month_end,
        SUM(amount) AS balance_fc
    FROM gl_transactions_with_suppliers
    GROUP BY supplier_name, gl_code, LAST_DAY(transaction_date)
),

fx_distinct AS (
    -- Step 2: Remove any duplicate FX rows
    SELECT DISTINCT month_end, currency, rate_to_lkr
    FROM fx_rates_manual
),

monthly_with_fx AS (
    -- Step 3: Join monthly balances with FX
    SELECT
        m.supplier_name,
        m.gl_code,
        m.month_end,
        m.balance_fc,
        f.rate_to_lkr,
        m.balance_fc * f.rate_to_lkr AS balance_lkr
    FROM monthly_balance m
    LEFT JOIN fx_distinct f
        ON m.month_end = f.month_end
        AND f.currency = 'USD'
)

-- Step 4: Calculate previous balance and revaluation gain/loss safely
SELECT
    supplier_name,
    gl_code,
    month_end,
    balance_fc,
    rate_to_lkr,
    balance_lkr,
    COALESCE(
        LAG(balance_lkr) OVER (PARTITION BY supplier_name ORDER BY month_end),
        0
    ) AS prev_balance_lkr,
    COALESCE(
        balance_lkr - LAG(balance_lkr) OVER (PARTITION BY supplier_name ORDER BY month_end),
        0
    ) AS reval_gain_loss
FROM monthly_with_fx
ORDER BY supplier_name, month_end;

