/* -------------------------------------------------------
   1️⃣ Q1 2025 Variance Report
   Combined view: variance, favorable/unfavorable status, reason
------------------------------------------------------- */
CREATE OR REPLACE VIEW vw_final_variance_q1_2025 AS
SELECT
    g.year,
    g.quarter,
    m.pnl_line,
    SUM(g.amount) AS actual_amount,
    SUM(b.budget_amount) AS budget_amount,
    SUM(g.amount) - SUM(b.budget_amount) AS variance_amount,
    ROUND(
        CASE WHEN SUM(b.budget_amount) <> 0
            THEN ((SUM(g.amount) - SUM(b.budget_amount)) / ABS(SUM(b.budget_amount))) 
            ELSE 0
        END, 2
    ) AS variance_percent,
    CASE 
        WHEN m.pnl_line = 'Revenue' AND SUM(g.amount) > SUM(b.budget_amount) THEN 'Favorable'
        WHEN m.pnl_line <> 'Revenue' AND SUM(g.amount) > SUM(b.budget_amount) THEN 'Unfavorable'
        ELSE 'Favorable'
    END AS variance_status,
    CASE 
        WHEN m.pnl_line = 'Revenue' THEN 'Higher sales and strong product demand'
        WHEN m.pnl_line = 'Opex' THEN 'Increased salaries and marketing campaigns'
        WHEN m.pnl_line = 'Depreciation' THEN 'New asset additions during the quarter'
        WHEN m.pnl_line = 'Tax' THEN 'Higher profit led to increased tax expense'
        ELSE 'N/A'
    END AS variance_reason
FROM gl_transactions g
LEFT JOIN budget b
    ON g.gl_code = b.gl_code
    AND g.year = b.year
    AND g.quarter = b.quarter
LEFT JOIN gl_mapping m
    ON g.gl_code = m.gl_code
WHERE g.year = 2025 AND g.quarter='Q1'
GROUP BY g.year, g.quarter, m.pnl_line
ORDER BY m.pnl_line;


/* -------------------------------------------------------
   2️⃣ Full-Year 2025 Variance
   Aggregated over all 4 quarters
------------------------------------------------------- */
CREATE OR REPLACE VIEW vw_full_year_2025_variance AS
SELECT
    m.pnl_line,
    SUM(g.amount) AS total_actual_2025,
    SUM(b.budget_amount) AS total_budget_2025,
    SUM(g.amount) - SUM(b.budget_amount) AS variance_amount,
    ROUND(
        CASE WHEN SUM(b.budget_amount) <> 0
            THEN ((SUM(g.amount) - SUM(b.budget_amount)) / ABS(SUM(b.budget_amount))) 
            ELSE 0
        END, 2
    ) AS variance_percent
FROM gl_transactions g
LEFT JOIN budget b
    ON g.gl_code = b.gl_code
    AND g.year = b.year
    AND g.quarter = b.quarter
LEFT JOIN gl_mapping m
    ON g.gl_code = m.gl_code
WHERE g.year = 2025
GROUP BY m.pnl_line
ORDER BY m.pnl_line;


