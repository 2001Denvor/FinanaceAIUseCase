 --Create Budget vs actual view                               
CREATE OR REPLACE VIEW vw_budget_vs_actual AS
SELECT
    g.year,
    g.quarter,
    m.pnl_line,

    SUM(g.amount) AS actual_amount,
    SUM(b.budget_amount) AS budget_amount,

    SUM(g.amount) - SUM(b.budget_amount) AS variance,

    ROUND(
        CASE 
            WHEN SUM(b.budget_amount) <> 0
            THEN (SUM(g.amount) - SUM(b.budget_amount)) 
                 / SUM(b.budget_amount)
            ELSE 0
        END
    ,4) AS variance_percent

FROM gl_transactions g
LEFT JOIN budget b
    ON g.gl_code = b.gl_code
    AND g.year = b.year
    AND g.quarter = b.quarter
LEFT JOIN gl_mapping m
    ON g.gl_code = m.gl_code
GROUP BY g.year, g.quarter, m.pnl_line;

