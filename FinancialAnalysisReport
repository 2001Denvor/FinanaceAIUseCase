--Prepare source table
CREATE OR REPLACE TABLE fa_assets (
    asset_code STRING,
    asset_name STRING,
    asset_group STRING,
    purchase_date DATE,
    purchase_value DECIMAL(18,2),
    useful_life_months INT,
    depreciation_method STRING,  -- 'SL' = Straight Line
    accumulated_depr DECIMAL(18,2)
);  

--CWIP table
CREATE OR REPLACE TABLE cwip (
    cwip_code STRING,
    asset_name STRING,
    asset_group STRING,
    cwip_amount DECIMAL(18,2),
    expected_cap_date DATE,
    useful_life_months INT,
    depreciation_method STRING
);

--Create a calendar /forecast table
-- Create a table with monthly forecast dates
CREATE OR REPLACE TABLE calendar_months AS
WITH months AS (
    SELECT add_months(to_date('2026-03-01'), seq) AS forecast_month
    FROM (SELECT posexplode(sequence(0,11)) AS (seq, val)) t
)
SELECT forecast_month
FROM months;

--Calculate Monthly Depreciation for Existing Assets
CREATE OR REPLACE VIEW monthly_fa_depr AS
SELECT
    c.forecast_month,
    a.asset_code,
    a.asset_group,
    a.purchase_value,
    a.useful_life_months,
    CASE 
        WHEN a.depreciation_method = 'SL' 
        THEN (a.purchase_value / a.useful_life_months)
        ELSE 0
    END AS monthly_depreciation
FROM fa_assets a
CROSS JOIN calendar_months c
WHERE c.forecast_month >= a.purchase_date
AND c.forecast_month < date_add(a.purchase_date, a.useful_life_months * 30); -- approximate end of life


--Calculate Monthly Depreciation for CWIP Assets
CREATE OR REPLACE VIEW monthly_cwip_depr AS
SELECT
    c.forecast_month,
    w.cwip_code AS asset_code,
    w.asset_group,
    w.cwip_amount AS purchase_value,
    w.useful_life_months,
    CASE 
        WHEN w.depreciation_method = 'SL' 
        THEN (w.cwip_amount / w.useful_life_months)
        ELSE 0
    END AS monthly_depreciation
FROM cwip w
CROSS JOIN calendar_months c
WHERE c.forecast_month >= w.expected_cap_date
AND c.forecast_month < date_add(w.expected_cap_date, w.useful_life_months * 30);


--Combine FA + CWIP Depreciation
CREATE OR REPLACE VIEW monthly_total_depr AS
SELECT
    forecast_month,
    asset_group,
    SUM(monthly_depreciation) AS total_depreciation
FROM (
    SELECT forecast_month, asset_group, monthly_depreciation FROM monthly_fa_depr
    UNION ALL
    SELECT forecast_month, asset_group, monthly_depreciation FROM monthly_cwip_depr
) t
GROUP BY forecast_month, asset_group
ORDER BY forecast_month, asset_group;

